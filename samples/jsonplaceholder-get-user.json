{
  "name": "Get user by ID (JSONPlaceholder demo)",
  "apiCode": "demo-jsonplaceholder-get-user",
  "description": "GET https://jsonplaceholder.typicode.com/users/{userId}. Path placeholder userId is taken from the JSON body (same pattern as the API tester). Remaining scalar fields become query parameters for GET.",
